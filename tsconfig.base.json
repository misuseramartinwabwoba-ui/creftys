{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "ignoreDeprecations": "6.0",

    "forceConsistentCasingInFileNames": true,

    "isolatedModules": true
  }
}